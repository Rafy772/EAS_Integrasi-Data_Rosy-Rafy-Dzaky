   "source": [
    "# Structural Topic Modeling (STM) for Donation Retention Literature Review\n",
    "# Pasang dependensi HANYA jika belum tersedia. Aman untuk lingkungan \"externally managed\"\n",
    "# (WSL/Debian/Ubuntu) yang menolak `pip install` biasa karena PEP 668.\n",
    "import importlib.util, subprocess, sys\n",
    "\n",
    "# nama paket pip -> nama modul yang diimpor (untuk pengecekan)\n",
    "_pkgs = {\n",
    "    'pandas': 'pandas', 'numpy': 'numpy', 'scikit-learn': 'sklearn', 'nltk': 'nltk',\n",
    "    'matplotlib': 'matplotlib', 'seaborn': 'seaborn', 'gensim': 'gensim',\n",
    "    'wordcloud': 'wordcloud', 'networkx': 'networkx',\n",
    "}\n",
    "_missing = [p for p, mod in _pkgs.items() if importlib.util.find_spec(mod) is None]\n",
    "\n",
    "if _missing:\n",
    "    print('Menginstal paket yang belum ada:', ', '.join(_missing))\n",
    "    for p in _missing:\n",
    "        try:\n",
    "            subprocess.run([sys.executable, '-m', 'pip', 'install', '-q',\n",
    "                            '--break-system-packages', p], check=True)\n",
    "            print(f'  ✓ {p}')\n",
    "        except subprocess.CalledProcessError:\n",
    "            print(f'  ! Gagal memasang {p} (dilewati — tidak wajib untuk notebook ini)')\n",
    "else:\n",
    "    print('✓ Semua dependensi sudah terpasang.')"
   ]
  },
