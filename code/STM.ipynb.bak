   ],
   "source": [
    "# Tentukan jumlah topik akhir berdasarkan grafik di atas (misal: 5)\n",
    "stm.num_topics = 5\n",
    "\n",
    "print(f\"\\n=== Fitting LDA Model ({stm.num_topics} topics) ===\")\n",
    "stm.lda_model = LatentDirichletAllocation(\n",
    "    n_components=stm.num_topics, random_state=stm.random_state,\n",
    "    max_iter=20, learning_method='online', n_jobs=-1\n",
    ")\n",
    "stm.lda_model.fit(stm.dtm)\n",
    "\n",
    "# Ekstraksi Kata Kunci per Topik\n",
    "feature_names = stm.vectorizer.get_feature_names_out()\n",
    "topics_dict = {}\n",
    "\n",
    "for topic_idx, topic in enumerate(stm.lda_model.components_):\n",
    "    top_indices = topic.argsort()[-10:][::-1]\n",
    "    top_words = [feature_names[i] for i in top_indices]\n",
    "    top_weights = [topic[i] for i in top_indices]\n",
    "\n",
    "    topic_name = f\"Topic {topic_idx + 1}\"\n",
    "    topics_dict[topic_name] = {'words': top_words, 'weights': top_weights}\n",
    "    print(f\"{topic_name}: {', '.join(top_words)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 591
    },
    "id": "fK9RsULkgpdP",
    "outputId": "15ca4a0d-79bc-4a61-de7e-1b5b66f64dd9"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=== Generating Topic Word Clouds ===\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1600x800 with 6 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(\"\\n=== Generating Topic Word Clouds ===\")\n",
    "cols = 3\n",
    "rows = (stm.num_topics + cols - 1) // cols\n",
    "fig, axes = plt.subplots(rows, cols, figsize=(16, 4*rows))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for idx, (topic_name, topic_data) in enumerate(topics_dict.items()):\n",
    "    word_freq = {w: float(wt) for w, wt in zip(topic_data['words'], topic_data['weights'])}\n",
    "    wordcloud = WordCloud(width=400, height=300, background_color='white', colormap='viridis').generate_from_frequencies(word_freq)\n",
    "\n",
    "    axes[idx].imshow(wordcloud, interpolation='bilinear')\n",
    "    axes[idx].set_title(topic_name, fontsize=12, fontweight='bold')\n",
    "    axes[idx].axis('off')\n",
    "\n",
    "for idx in range(len(topics_dict), len(axes)):\n",
    "    axes[idx].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(output_dir, 'topic_wordclouds.png'), dpi=300)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 525
    },
    "id": "QsoRCO7ZgvyG",
    "outputId": "fe73444e-37bd-491c-f69a-709a15b4c2d6"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=== Calculating Topic Distributions & Trends ===\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1800x800 with 8 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(\"\\n=== Calculating Topic Distributions & Trends ===\")\n",
    "doc_topic_dist = stm.lda_model.transform(stm.dtm)\n",
    "doc_topic_df = pd.DataFrame(doc_topic_dist, columns=[f'Topic_{i+1}' for i in range(stm.num_topics)])\n",
    "\n",
    "# Tren Berdasarkan Tahun\n",
    "trend_data = pd.concat([stm.documents[['year']], doc_topic_df], axis=1)\n",
    "yearly_trends = trend_data.groupby('year').mean()\n",
    "\n",
    "# Plot Tren\n",
    "fig, axes = plt.subplots((stm.num_topics + 3) // 4, min(stm.num_topics, 4), figsize=(18, 8))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for topic_idx in range(stm.num_topics):\n",
    "    ax = axes[topic_idx]\n",
    "    topic_col = f'Topic_{topic_idx + 1}'\n",
    "    yearly_trends[topic_col].plot(ax=ax, marker='o', linewidth=2, color=f'C{topic_idx}')\n",
    "    ax.set_title(f'Topic {topic_idx + 1} Trend')\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "for idx in range(stm.num_topics, len(axes)):\n",
    "    axes[idx].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(output_dir, 'topic_trends.png'), dpi=300)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 843
    },
    "id": "vdNtZJ1Lg0CV",
    "outputId": "31380175-757b-4ecb-b0e1-739232b1daed"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=== Topic Correlations & Network ===\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x800 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(\"\\n=== Topic Correlations & Network ===\")\n",
    "topic_cols = [f'Topic_{i+1}' for i in range(stm.num_topics)]\n",
    "correlation_matrix = doc_topic_df[topic_cols].corr()\n",
    "\n",
    "# Buat Jaringan (Network)\n",
    "G = nx.Graph()\n",
    "threshold = 0.1 # Disesuaikan agar memunculkan relasi pada sampel kecil\n",
    "\n",
    "for i in range(len(correlation_matrix)):\n",
    "    for j in range(i+1, len(correlation_matrix)):\n",
    "        if abs(correlation_matrix.iloc[i, j]) > threshold:\n",
    "            G.add_edge(f'Topic {i+1}', f'Topic {j+1}', weight=abs(correlation_matrix.iloc[i, j]))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "pos = nx.spring_layout(G, k=2, seed=42)\n",
    "weights = [G[u][v]['weight'] for u, v in G.edges()]\n",
    "\n",
    "nx.draw_networkx_edges(G, pos, width=[w*5 for w in weights], alpha=0.6, ax=ax, edge_color='gray')\n",
    "nx.draw_networkx_nodes(G, pos, node_color='lightblue', node_size=2000, ax=ax)\n",
    "nx.draw_networkx_labels(G, pos, font_size=10, font_weight='bold', ax=ax)\n",
    "\n",
    "ax.set_title('Topic Correlation Network')\n",
    "ax.axis('off')\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(output_dir, 'topic_network.png'), dpi=300)\n",
    "plt.show()"
   ]
  },
