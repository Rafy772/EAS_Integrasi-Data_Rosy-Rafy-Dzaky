   ],
   "source": [
    "# === Representasi HTML dari abstrak per topik (topic_1 .. topic_5) ===\n",
    "import html as _html\n",
    "\n",
    "html_path = os.path.join(output_dir, 'topic_abstracts.html')\n",
    "palette = ['#2563eb', '#059669', '#d97706', '#dc2626', '#7c3aed',\n",
    "           '#0891b2', '#db2777', '#65a30d', '#9333ea', '#ea580c']\n",
    "\n",
    "# Muat kembali tiap CSV per-topik (sumber data sesuai permintaan)\n",
    "topic_frames = {}\n",
    "for t in range(1, stm.num_topics + 1):\n",
    "    fpath = os.path.join(by_topic_dir, f'topic_{t}_documents.csv')\n",
    "    topic_frames[t] = pd.read_csv(fpath) if os.path.exists(fpath) else pd.DataFrame()\n",
    "total_docs = sum(len(d) for d in topic_frames.values())\n",
    "\n",
    "def _esc(x):\n",
    "    return _html.escape(str(x))\n",
    "\n",
    "parts = ['''<!DOCTYPE html>\n",
    "<html lang=\"id\"><head><meta charset=\"utf-8\">\n",
    "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n",
    "<title>Abstrak per Topik - STM</title>\n",
    "<style>\n",
    ":root{font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;}\n",
    "body{margin:0;background:#f5f6f8;color:#1f2430;line-height:1.6;}\n",
    "header{background:#111827;color:#fff;padding:28px 40px;}\n",
    "header h1{margin:0 0 6px;font-size:24px;}\n",
    "header p{margin:0;color:#9ca3af;font-size:14px;}\n",
    "nav.toc{display:flex;flex-wrap:wrap;gap:10px;padding:18px 40px;background:#fff;\n",
    "        border-bottom:1px solid #e5e7eb;position:sticky;top:0;}\n",
    "nav.toc a{text-decoration:none;padding:8px 14px;border-radius:999px;\n",
    "          background:#eef2ff;color:#3730a3;font-size:13px;font-weight:600;}\n",
    "main{max-width:1000px;margin:0 auto;padding:24px 20px 80px;}\n",
    "section.topic{margin:30px 0;}\n",
    "section.topic h2{display:flex;align-items:center;gap:10px;font-size:20px;margin:0 0 4px;}\n",
    ".dot{width:14px;height:14px;border-radius:50%;display:inline-block;}\n",
    ".kw{color:#6b7280;font-size:13px;margin:0 0 14px;}\n",
    ".card{background:#fff;border:1px solid #e5e7eb;border-left:4px solid #ccc;\n",
    "      border-radius:10px;padding:16px 18px;margin:12px 0;box-shadow:0 1px 2px rgba(0,0,0,.04);}\n",
    ".card .title{font-weight:600;font-size:15px;margin:0 0 6px;}\n",
    ".meta{font-size:12px;color:#6b7280;margin:0 0 10px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;}\n",
    ".badge{background:#f3f4f6;border-radius:6px;padding:2px 8px;}\n",
    ".abstract{font-size:14px;color:#374151;margin:0;text-align:justify;}\n",
    ".empty{color:#9ca3af;font-style:italic;}\n",
    "</style></head><body>''']\n",
    "\n",
    "parts.append(f'<header><h1>Representasi Abstrak per Topik</h1>'\n",
    "             f'<p>Structural Topic Modeling &middot; {total_docs} dokumen &middot; '\n",
    "             f'{stm.num_topics} topik</p></header>')\n",
    "\n",
    "toc = ''.join(f'<a href=\"#topic{t}\">Topik {t} ({len(topic_frames[t])})</a>'\n",
    "              for t in range(1, stm.num_topics + 1))\n",
    "parts.append(f'<nav class=\"toc\">{toc}</nav>')\n",
    "\n",
    "parts.append('<main>')\n",
    "for t in range(1, stm.num_topics + 1):\n",
    "    color = palette[(t - 1) % len(palette)]\n",
    "    sub = topic_frames[t]\n",
    "    kw = topic_keywords.get(t, '')\n",
    "    parts.append(f'<section class=\"topic\" id=\"topic{t}\">')\n",
    "    parts.append(f'<h2><span class=\"dot\" style=\"background:{color}\"></span>Topik {t}</h2>')\n",
    "    parts.append(f'<p class=\"kw\">Kata kunci: <b>{_esc(kw)}</b> &mdash; {len(sub)} dokumen</p>')\n",
    "    if len(sub) == 0:\n",
    "        parts.append('<p class=\"empty\">Tidak ada dokumen pada topik ini.</p>')\n",
    "    for _, r in sub.iterrows():\n",
    "        parts.append(\n",
    "            f'<article class=\"card\" style=\"border-left-color:{color}\">'\n",
    "            f'<p class=\"title\">{_esc(r[\"title\"])}</p>'\n",
    "            f'<p class=\"meta\"><span class=\"badge\">{_esc(r[\"year\"])}</span>'\n",
    "            f'<span>{_esc(r[\"journal\"])}</span>'\n",
    "            f'<span class=\"badge\">p = {float(r[\"dominant_topic_prob\"]):.2f}</span></p>'\n",
    "            f'<p class=\"abstract\">{_esc(r[\"abstract\"])}</p></article>')\n",
    "    parts.append('</section>')\n",
    "parts.append('</main></body></html>')\n",
    "\n",
    "with open(html_path, 'w', encoding='utf-8') as f:\n",
    "    f.write('\\n'.join(parts))\n",
    "print(f\"HTML tersimpan di: {html_path}\")\n",
    "print(f\"Total {total_docs} abstrak dari {stm.num_topics} topik.\")\n",
    "\n",
    "# Tampilkan langsung di dalam notebook\n",
    "from IPython.display import IFrame, display\n",
    "display(IFrame(src=os.path.relpath(html_path), width='100%', height=600))"
   ]
  }
 ],
