     "text": [
      "\n",
      "=== Creating Document-Term Matrix ===\n",
      "Document-Term Matrix shape: (136, 1838)\n",
      "Vocabulary size: 1838\n"
     ]
    }
   ],
   "source": [
    "print(\"\\n=== Creating Document-Term Matrix ===\")\n",
    "# min_df=2 membuang istilah yang hanya muncul di satu dokumen (mengurangi noise pada data nyata)\n",
    "stm.vectorizer = TfidfVectorizer(max_features=5000, min_df=2, max_df=0.8, stop_words='english')\n",
    "stm.dtm = stm.vectorizer.fit_transform(stm.documents['processed_text'])\n",
    "\n",
    "feature_names = stm.vectorizer.get_feature_names_out()\n",
    "print(f\"Document-Term Matrix shape: {stm.dtm.shape}\")\n",
    "print(f\"Vocabulary size: {len(feature_names)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 430
    },
    "id": "qpdTBw6GgjJr",
    "outputId": "303552fc-bf72-4a79-a05e-9877053cb424"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "=== Finding Optimal Number of Topics ===\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x500 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(\"\\n=== Finding Optimal Number of Topics ===\")\n",
    "coherence_scores = []\n",
    "perplexity_scores = []\n",
    "topic_range = range(2, 8) # Range diperkecil menyesuaikan volume data sampel\n",
    "\n",
    "for num_topics in topic_range:\n",
    "    lda = LatentDirichletAllocation(n_components=num_topics, random_state=stm.random_state, n_jobs=-1, max_iter=10)\n",
    "    lda.fit(stm.dtm)\n",
    "    perplexity = lda.perplexity(stm.dtm)\n",
    "    perplexity_scores.append(perplexity)\n",
    "    coherence_scores.append(-perplexity)\n",
    "\n",
    "# Plotting langsung di dalam notebook\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "ax1.plot(topic_range, perplexity_scores, 'o-', linewidth=2, markersize=8)\n",
    "ax1.set_title('Model Perplexity vs Number of Topics')\n",
    "ax2.plot(topic_range, coherence_scores, 'o-', linewidth=2, markersize=8, color='orange')\n",
    "ax2.set_title('Model Coherence vs Number of Topics')\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(output_dir, 'optimal_topics.png'), dpi=300)\n",
    "plt.show()"
   ]
  },
