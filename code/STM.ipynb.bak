   "source": [
    "# === Ekspor dokumen ke masing-masing topik ===\n",
    "# Tiap dokumen ditetapkan ke \"topik dominan\" (probabilitas tertinggi),\n",
    "# lalu disimpan terpisah per topik + satu berkas gabungan berlabel.\n",
    "\n",
    "topic_cols = [f'Topic_{i+1}' for i in range(stm.num_topics)]\n",
    "\n",
    "# Gabungkan metadata dokumen dengan distribusi topik\n",
    "docs_topics = stm.documents[['title', 'year', 'journal', 'abstract']].reset_index(drop=True).copy()\n",
    "docs_topics = pd.concat([docs_topics, doc_topic_df.reset_index(drop=True)], axis=1)\n",
    "docs_topics['dominant_topic'] = doc_topic_df.values.argmax(axis=1) + 1\n",
    "docs_topics['dominant_topic_prob'] = doc_topic_df.values.max(axis=1).round(4)\n",
    "\n",
    "# Kata kunci ringkas tiap topik (dari topics_dict pada sel pemodelan)\n",
    "topic_keywords = {i + 1: ', '.join(topics_dict[f'Topic {i+1}']['words'][:5])\n",
    "                  for i in range(stm.num_topics)}\n",
    "\n",
    "# Folder khusus per-topik\n",
    "by_topic_dir = os.path.join(output_dir, 'by_topic')\n",
    "os.makedirs(by_topic_dir, exist_ok=True)\n",
    "\n",
    "ordered_cols = (['title', 'year', 'journal', 'dominant_topic', 'dominant_topic_prob']\n",
    "                + topic_cols + ['abstract'])\n",
    "\n",
    "print(f\"Total dokumen: {len(docs_topics)}\\n\")\n",
    "for t in range(1, stm.num_topics + 1):\n",
    "    sub = (docs_topics[docs_topics['dominant_topic'] == t]\n",
    "           .sort_values('dominant_topic_prob', ascending=False))\n",
    "    fname = os.path.join(by_topic_dir, f'topic_{t}_documents.csv')\n",
    "    sub[ordered_cols].to_csv(fname, index=False)\n",
    "\n",
    "    print(f\"Topik {t} [{topic_keywords[t]}] — {len(sub)} dokumen  ->  {fname}\")\n",
    "    for _, r in sub.iterrows():\n",
    "        print(f\"   ({r['dominant_topic_prob']:.2f}) {r['year']}  {str(r['title'])[:80]}\")\n",
    "    print()\n",
    "\n",
    "# Berkas gabungan dengan label topik dominan untuk semua dokumen\n",
    "all_fname = os.path.join(output_dir, 'documents_with_dominant_topic.csv')\n",
    "docs_topics[ordered_cols].to_csv(all_fname, index=False)\n",
    "print(f\"Berkas gabungan semua dokumen: {all_fname}\")\n",
    "docs_topics[['title', 'year', 'dominant_topic', 'dominant_topic_prob']].head(10)"
   ]
  },
