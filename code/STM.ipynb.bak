   "source": [
    "# === Gunakan data Scopus Anda sebagai input ===\n",
    "# CSV_PATH sudah ditentukan otomatis di sel impor di atas (tahan terhadap working directory).\n",
    "# Kecualikan dokumen non-studi-primer: review, conference review, dan erratum.\n",
    "stm.load_data(filepath=CSV_PATH, sample_data=False,\n",
    "              exclude_doc_types=('review', 'conference review', 'erratum'))\n",
    "\n",
    "print(\"\\n=== Text Preprocessing ===\")\n",
    "stm.documents['processed_text'] = stm.documents['abstract'].apply(stm.preprocess_text)\n",
    "print(\"✓ Preprocessing complete\")\n",
    "stm.documents[['title', 'processed_text']].head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {
